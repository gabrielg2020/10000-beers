# Database Configuration
POSTGRES_PASSWORD=beers_secure_password_change_me
DATABASE_URL=postgresql://beers:beers_secure_password_change_me@postgres:5432/beers

# WhatsApp Configuration
WHATSAPP_GROUP_ID=1234567890@g.us

# Admin Configuration (comma-separated WhatsApp IDs)
ADMIN_IDS=447123456789@c.us,447987654321@c.us

# Storage Configuration
IMAGE_STORAGE_PATH=/data/images
MAX_IMAGE_SIZE_MB=10

# Bot Behaviour
SUBMISSION_COOLDOWN_MINUTES=0
# When false, the bot stays silent on AI rejection ("Doesn't look like a beer to me mate")
REPLY_ON_SUBMISSION=true
# Seconds to wait before initialising the WhatsApp client. Set to 10-30 on slow hardware if seeing init races.
STARTUP_WAIT=0

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info

# pgAdmin Configuration (for local development only)
PGADMIN_EMAIL=admin@localhost.com
PGADMIN_PASSWORD=admin

# AI Configuration
AI_ENABLED=false
AI_CONFIDENCE_THRESHOLD=0.9
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# GitHub Release Configuration (for !release command)
GITHUB_REPO_OWNER=gabrielg2020
GITHUB_REPO_NAME=10000-beers
